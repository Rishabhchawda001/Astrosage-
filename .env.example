# ────────────────────────────────────────────────────────────────
# AstroSage AI — Environment Configuration
# ────────────────────────────────────────────────────────────────
# Copy to .env and fill in values.
# NEVER commit .env to version control.

# Application
APP_ENVIRONMENT=development
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Authentication
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (optional, for production)
DATABASE_URL=postgresql+asyncpg://astrosage:astrosage-dev@localhost:5432/astrosage

# Redis (optional, for production)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# AI Model (future phases)
LOCAL_MODEL=
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_TOKENS=4096
TEMPERATURE=0.7

# Knowledge Base
KNOWLEDGE_BASE_PATH=knowledge/releases/v1.0.0

# Monitoring
SENTRY_DSN=
OTLP_ENDPOINT=
