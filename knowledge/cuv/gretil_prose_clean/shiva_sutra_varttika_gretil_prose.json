          "body": "* [<śivasūtravārtika:> * teṣāṃ sṛṣṭyādibhāvānāṃ pravṛttāv apy anāratam || SivSV_3.32:1 ||"
        },
        {
          "ref": null,
          "body": "* viśvasṛṣṭisthitidhvaṃseṣv aprakampasya yoginaḥ || SivSV_3.32:13 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * uttīrṇadehaprāṇādipramātṛtvasya dhīmataḥ || SivSV_3.33:1 ||"
        },
        {
          "ref": null,
          "body": "* yato na tatsukhādyantas tata evaiṣa sādhakaḥ || SivSV_3.33:11 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tābhyāṃ mukto viśeṣeṇa yogīndro yat tayor yataḥ || SivSV_3.34:1 ||"
        },
        {
          "ref": null,
          "body": "* tad evāha tuśabdoktam antaraṃ candraśekharaḥ || SivSV_3.34:5 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * mohaḥ svākhyātir ajñānaṃ tena yaḥ pratisaṃhataḥ || SivSV_3.35:1 ||"
        },
        {
          "ref": null,
          "body": "* svātantryayogaḥ sahajaḥ prādurasti tadāsya tu || SivSV_3.35:6 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * bhedasya dehaprāṇādimitāhaṃkṛtijanmanaḥ || SivSV_3.36:1 ||"
        },
        {
          "ref": null,
          "body": "* na caitad apy asaṃbhāvyaṃ sraṣṭṛtvaṃ yogino yataḥ || SivSV_3.36:7 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * svataḥ svasmād anubhavāt svapnasaṃkalpanādiṣu || SivSV_3.37:1 ||"
        },
        {
          "ref": null,
          "body": "* tirohitāyāḥ svātantryaśakter uttejanaṃ prati || SivSV_3.37:8 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tripadaṃ jāgarāsvapnasauṣuptānām anukramāt || SivSV_3.38:1 ||"
        },
        {
          "ref": null,
          "body": "* tripadādiprāṇanam ity etad uktam athāpi tu || SivSV_3.38:15 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * anuprāṇanam ity etad ādadyād iti śiṣyate || SivSV_3.39:1 ||"
        },
        {
          "ref": null,
          "body": "* apūrṇamanyatārūpād asyāṇavamalātmanaḥ || SivSV_3.39:10 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tattvaiḥ śaktigaṇākrāntair dharaṇyantaiḥ kalādibhiḥ || SivSV_3.40:1 ||"
        },
        {
          "ref": null,
          "body": "* api tūktacarasvātmārāmataiveti kathyate || SivSV_3.40:9 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tad ityuktacare dhāmni saṃvettṛtvasvarūpiṇi || SivSV_3.41:1 ||"
        },
        {
          "ref": null,
          "body": "* ity āśaṅkyottaraṃ vakti bhagavān viśvadaiśikaḥ || SivSV_3.41:9 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tadety uktābhilāṣasya praśamāj jīvasaṃkṣaye || SivSV_3.42:1 ||"
        },
        {
          "ref": null,
          "body": "* kasmād ity api śaṅkāyām uttaraṃ vakti śaṃkaraḥ || SivSV_3.42:9 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * prāṇe pariṇatā saṃvit prāg iti proktayā diśā || SivSV_3.43:1 ||"
        },
        {
          "ref": null,
          "body": "* ity upāyopasaṃhāramukhenāha maheśvaraḥ || SivSV_3.43:20 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * netrādiromarandhrāntanāḍīnāṃ niviḍātmanām || SivSV_3.44:1 ||"
        },
        {
          "ref": null,
          "body": "* upasaṃharati śrīmān uktaṃ prakaraṇaṃ śivaḥ || SivSV_3.44:17 ||]"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * punaś ca proktacaitanyasvarūponmīlanātmakam || SivSV_3.45:1 ||"
        },
        {
          "ref": null,
          "body": "* anugṛhṇantu nāmaitat santaḥ saṃtoṣam āgatāḥ || SivSV_3.45:19 ||]"
        }
      ]
    }
  ]
}