  "chapters": [
    {
      "chapter_num": 0,
      "aku_count": 16,
      "akus": [
        {
          "ref": null,
          "body": "iti āṅgirasam |"
        },
        {
          "ref": null,
          "body": "ityāṅgirasasmṛtau pūrvāṅgirasaṃ samāptam |"
        },
        {
          "ref": null,
          "body": "ityaṅgirasadharmaśāstre upoddhāto nāma prathamo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre pariṣadupasthānaṃ nāma dvitīyo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre prāyaścittavidhānaṃ nāma tṛtīyo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre pariṣallakṣaṇaṃ nāma caturtho 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre prāyaścittaniyantukathanaṃ nāma pañcamo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre prāyaścittācārakathanaṃ nāma ṣaṣṭho 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre pāpaparigaṇanaṃ nāma saptamo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre śūdrānnādiniṣedhakathanaṃ nāmāṣṭamo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre abhakṣyabhakṣaṇaprāyaścittavidhirnāma navamo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre hiṃsāyāyaścittakathanaṃ nāma daśamo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ityāṅgirasadharmaśāstre govadhaprāyaścittaṃ nāmaikādaśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ity āṅgirasadharmaśāstre kṛcchrādisvarūpakathanaṃ nāma dvādaśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "ity uttarāṅgirasam"
        },
        {
          "ref": null,
          "body": "ity āṅgirasasmṛtiḥ"
        }
      ]
    }
  ]
}