  "title": "Svayaṃbhupurāṇa",
  "total_chapters": 2,
  "total_akus": 48,
  "chapters": [
    {
      "chapter_num": 0,
      "aku_count": 47,
      "akus": [
        {
          "ref": null,
          "body": "Svayambhu Purāṇa prathama adhyāya"
        },
        {
          "ref": null,
          "body": "svayambhūdharmadhātusamutpatti nidānakathā"
        },
        {
          "ref": null,
          "body": "om namaḥ śrī dharmadhātuvāgīśvarāya sarva buddhadharmabodhisattvebhyaḥ /"
        },
        {
          "ref": null,
          "body": "puṇyakṣetreṣu tīrtheṣu vihāre sugatāśrame //"
        },
        {
          "ref": null,
          "body": "bodhimārge samāyujya saṃcārayitumarhati //"
        },
        {
          "ref": null,
          "body": "maitreyādi samālokāḥ sarve 'pi saṃprasedire /"
        },
        {
          "ref": null,
          "body": "iti svayambhūdharmadhātu samutpatti nidānakathā prathamo 'dhyāyaḥ samāptaḥ /"
        },
        {
          "ref": null,
          "body": "dvitīya adhyāya pūjāphalavarṇano nāma"
        },
        {
          "ref": null,
          "body": "tadanujñāṃ pradatvātra saṃprasādayatumarhati //"
        },
        {
          "ref": null,
          "body": "śraddhayā samupāśritya prabhajāmi mahotsavaiḥ //"
        },
        {
          "ref": null,
          "body": "ratnapāṇiṃ mahāsattvaṃ saṃpaśyannevamādiśat //"
        },
        {
          "ref": null,
          "body": "jitvā māragaṇān sarvān dharmādhipo bhavāmyahaṃ //"
        },
        {
          "ref": null,
          "body": "te te sarve 'pi saṃbodhiṃ prāpya syuḥ sugatā drutaṃ //"
        },
        {
          "ref": null,
          "body": "durgati naiva gaccheyuḥ kutrāpi hi kadācana //"
        },
        {
          "ref": null,
          "body": "pravārya śraddhayā bhaktyā saṃbhajante samādarāt //"
        },
        {
          "ref": null,
          "body": "vitatyoccai vitānaṃ ca sasevyante samādarāt //"
        },
        {
          "ref": null,
          "body": "tathāgateṣu saddharmma saṃbuddha śrāvakeṣvapi //"
        },
        {
          "ref": null,
          "body": "aśokaḥ sasabhālokaḥ prābhyanandaṃ prabodhitaḥ /"
        },
        {
          "ref": null,
          "body": "iti śrī svayambhūtpatti kathāyā śrī svayambhū bhaṭṭārakoddeśa pūjāvarṇanā nāma dvītīyo 'dhyāya samāpta /"
        },
        {
          "ref": null,
          "body": "tṛtīya adhyāya mahāhradaśoṣaṇadharmadhātupadmagiri sampratiṣṭhāpanno nāma"
        },
        {
          "ref": null,
          "body": "iti śrī svayambhūtpattisamuddeśa mahāhrada śoṣaṇa dharmmadhātu padmagirisaṃprasthāpano nāma tṛtīyo 'dhyāyaḥ /"
        },
        {
          "ref": null,
          "body": "caturtha adhyāyaḥ śrīsvayambhūcaityasamutpattikathā vītarāgatīrtharāṣṭrapravartano nāma"
        },
        {
          "ref": null,
          "body": "tato 'nyepi samāyātāḥ sarvadigbhyo 'tra sarvataḥ //"
        },
        {
          "ref": null,
          "body": "iti śrī svayaṃbhū caitya samutpatti kathā vītarāgatīrtha rāṣṭra pravarttano nāma caturtho 'dhyāyaḥ samāptaḥ /"
        },
        {
          "ref": null,
          "body": "pañcama adhyāyaḥ svayambhūtpatyaneka tīrthasaṃjātapuṇyamahātmyavarṇano nāma"
        },
        {
          "ref": null,
          "body": "pāpa saṃśodhanaṃ puṇyaṃ saddharmmasukhasādhanaṃ //"
        },
        {
          "ref": null,
          "body": "maitreyādi sabhālokāḥ prāpyananda pravodhitāḥ /"
        },
        {
          "ref": null,
          "body": "iti śrī svayaṃbhū samutpatti kathāyāṃ aneka tīrtha saṃjāta puṇya mahātmya varṇano nāma pañcamo 'dhyāya /"
        },
        {
          "ref": null,
          "body": "ṣaṣṭhama adhyāyaḥ svayambhūdharmadhātuvāgīśvarābhidhānaprasiddhapravartano nāma"
        },
        {
          "ref": null,
          "body": "saddharmaṃ samupādiśya sarvān lokān pravodhaya //"
        },
        {
          "ref": null,
          "body": "itiśrī svayaṃbhū dharmmadhātu vāgīśvarābhidhāna prasiddha pravartano nāma ṣaṣṭho 'dhyāyaḥ /"
        },
        {
          "ref": null,
          "body": "saptama adhyāyaḥ svayambhūdharmadhātuvāgīśvaragutikṛtapravartano nāma"
        },
        {
          "ref": null,
          "body": "brahmacārī yatirbhikṣuniḥ kleśorhan sudhīrabhūt //"
        },
        {
          "ref": null,
          "body": "iti śrīsvayaṃbhūdharmmadhātuvāgīśvara guptikṛta pravarttano nāma saptamo 'dhyāyaḥ samāptaḥ /"
        },
        {
          "ref": null,
          "body": "aṣṭama adhyāyaḥ svayambhūcaityāśramanāma sādhanāsuvṛṣṭicaraṇo nāma"
        },
        {
          "ref": null,
          "body": "varuṇo nāgarājāpi praduṣṭaḥ krūracakṣuṣā //"
        },
        {
          "ref": null,
          "body": "yadyatra nṛpatiḥ samyaga vicārya pramādataḥ //"
        },
        {
          "ref": null,
          "body": "iti svayambhū caityāśramanāmasādhanasuvṛṣṭicāraṇo nāmāṣṭamo 'dhyāyaḥ /"
        },
        {
          "ref": null,
          "body": "navama adhyāyaḥ śrīmahācārya śāntikaraguṇasaṃsiddhimahātmyānubhāva prakathanapravartano nāma"
        },
        {
          "ref": null,
          "body": "evamasau mahāsattvo bhadraśrīsadguṇārthabhṛt //"
        },
        {
          "ref": null,
          "body": "iti śrīmahācāryaśāntikaraguṇasaṃsiddhimāhātmyānubhāvaprakathanapravṛtto nāmādhyāya navamaḥ /"
        },
        {
          "ref": null,
          "body": "daśama adhyāyaḥ śrī dharmmadhātusvayambhūtpattidharmmamāhātmyasubhāṣitasūtraṃ nāma"
        },
        {
          "ref": null,
          "body": "iti śrī dharmmadhātusvayambhūtpattidharmmamāhātmyasubhāṣitasūtraṃ daśama adhyāyaḥ samāptaḥ //"
        },
        {
          "ref": null,
          "body": "śubhamastu //"
        },
        {
          "ref": null,
          "body": "deyadharmo 'yaṃ pravaramahāyāyinaḥ śrīmatrudravarṇṇamahāvihārāvasthitaḥ paramopāsakaśrīśākyavaṃśodbhavaḥ śrīrāmānandena likhito 'gamat saṃpūrṇṇa //"
        },
        {
          "ref": null,
          "body": "śubhamastu sarvadāḥ //"
        },
        {
          "ref": null,
          "body": "śrīrāmānandayā pustaka juro / śubhaṃ / upasargga / maharādaharāścaiva śītarāpūṭaloka vā / upasarggī mahāmārī saptaite lokahārakaḥ // saṃvat"
        }
      ]
    },
    {
      "chapter_num": 934,
