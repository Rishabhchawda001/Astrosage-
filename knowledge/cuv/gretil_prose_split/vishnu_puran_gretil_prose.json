        {
          "ref": null,
          "body": "iti viṣṇumahāpurāṇe caturthāṃśe saptadaśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "śrīparāśara uvāca yayāleścāturthaputrasyānoḥsabhānalacakṣuḥ parameṣusaṃjñāstrayaḥ putrā babhūvuḥ //"
