        {
          "ref": null,
          "body": "SivSV_1.1:14 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * ajñānam iti tatrādyaṃ caitanyasphārarūpiṇi ||"
