          "ref": null,
          "body": "SivSV_1.17:4 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * bhūtānāṃ dehadhīprāṇaśūnyānāṃ grāhakātmanām ||"
