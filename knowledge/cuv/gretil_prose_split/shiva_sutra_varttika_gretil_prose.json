        {
          "ref": null,
          "body": "śivasūtra, prathama unmeṣa caitanyam ātmā //"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * caitanyaṃ citkriyārūpaṃ śivasya paramasya yat ||"
