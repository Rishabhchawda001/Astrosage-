          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * prekṣakāṇīti saṃsāranāṭyaprākaṭyakṛd vapuḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.11:1 ||"
        },
        {
          "ref": null,
          "body": "* ity evaṃ prekṣakībhūtasvākṣacakrasya yoginaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.11:3 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * dhīs tāttvikasvacidrūpavimarśakuśalā matiḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.12:1 ||"
        },
        {
          "ref": null,
          "body": "* evaṃ nijasphurattātmasattvāsādanavaibhavāt ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.12:4 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * siddhaḥ sampanna evāsya bhavet paramayoginaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.13:1 ||"
        },
        {
          "ref": null,
          "body": "* svatantrabhāva evāsya svānandabharitātmanaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.13:4 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * yatra svābhāvike dehe sphuṭībhūtā svatantratā ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.14:1 ||"
        },
        {
          "ref": null,
          "body": "* na caivam apy udāsīnena bhāvyaṃ yogināpi tu ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.14:4 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * sphurattātmā parā śaktir bījaṃ viśvasya kāraṇam ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.15:1 ||"
        },
        {
          "ref": null,
          "body": "* evaṃvidho mahāyogī paraśaktyavadhānavān ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.15:4 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * āsyate sthīyate yasminn aikātmyeneti cāsanam ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.16:1 ||"
        },
        {
          "ref": null,
          "body": "* prasphuracchāmbhavāvaśavaibhavaḥ sādhakottamaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.16:12 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * svasya sambandhinī mātrā caitanyasyoktarūpiṇaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.17:1 ||"
        },
        {
          "ref": null,
          "body": "* punarjanmādisambandho na kaścid iti kathyate ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.17:6 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * vidyeti sahajā tasyā avināśaḥ sadodayaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.18:1 ||"
        },
        {
          "ref": null,
          "body": "* tadā tanmohanāyaiva samuttiṣṭhanti śaktayaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.18:6 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * kavargādiṣu tiṣṭhantyas tadadhiṣṭhātṛtāṃ gatāḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.19:1 ||"
        },
        {
          "ref": null,
          "body": "* paśūn pramāt ||"
        },
        {
          "ref": null,
          "body": "* tathā sarvāsv avasthāsu yukto bhūyād itīryate ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.19:14 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * triṣv iti proktarūpeṣu jāgarādiṣu tailavat ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.20:1 ||"
        },
        {
          "ref": null,
          "body": "* atropāyaṃ punaś cāha turyāmṛtaniṣecane ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.20:16 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * prāṇāyāmādikaṃ tyaktvā sthūlopāyaṃ vikalpakam ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.21:1 ||"
        },
        {
          "ref": null,
          "body": "* yadā bhūyaḥ prasaraṇaṃ yogino jāyate tadā ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.21:7 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * prāṇasya prasphuracchāktasaurabhāveśasaṃskṛtaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.22:1 ||"
        },
        {
          "ref": null,
          "body": "* āste yogī tadāmuṣya tāvan mātreṇa tuṣyataḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.22:8 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * pūrvasyām aparasyāṃ ca koṭau turyaniṣeviṇaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.23:1 ||"
        },
        {
          "ref": null,
          "body": "* turyāvaṣṭambharasatas turyātītaṃ parāmṛśet ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.23:6 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * mātrāḥ padārthāḥ rūpādyās tāsv ebhiś cakṣurādibhiḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.24:1 ||"
        },
        {
          "ref": null,
          "body": "* evam udyatsamāveśaprakarṣaḥ sādhakarṣabhaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.24:7 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * turyābhyāsaprakarṣeṇa turyātītātmakaṃ padam ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.25:1 ||"
        },
        {
          "ref": null,
          "body": "* kalevarasthitis tasya kartavyety upadiśyate ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.25:10 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * evaṃ pūrvoktayā nītyā śivatulyasya yoginaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.26:1 ||"
        },
        {
          "ref": null,
          "body": "* evaṃvidhasya tasyāsya yā yā svālāparūpiṇī ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.26:8 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * mahāmantramayaṃ naumi rūpaṃ te svacchaśītalam ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.27:1 ||"
        },
        {
          "ref": null,
          "body": "* atha cāsyocyate caryā maryādānuvidhāyinī ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.27:14 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * proktacaitanyarūpasya sākṣātkaraṇamātmanaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.28:1 ||"
        },
        {
          "ref": null,
          "body": "* ity āha bhagavān īśo nityānugrahakārakaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.28:12 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * avīn paśujanān pātīty avipaṃ śaktimaṇḍalam ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.29:1 ||"
        },
        {
          "ref": null,
          "body": "* ity evam avipasthasya jñāhetor asya yoginaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.29:11 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * śaktayo 'sya jagat kṛtsnaṃ śaktimāṃs tu maheśvaraḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.30:1 ||"
        },
        {
          "ref": null,
          "body": "* svaśaktipracayo viśvaṃ yāvat tatpṛṣṭhapātinau ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.30:7 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * svaśaktipracayau proktau tāv apīty anuvartate ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.31:1 ||"
        },
        {
          "ref": null,
          "body": "* ity āśaṅkānivṛttyarthaṃ sūtram āha maheśvaraḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.31:10 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * teṣāṃ sṛṣṭyādibhāvānāṃ pravṛttāv apy anāratam ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.32:1 ||"
        },
        {
          "ref": null,
          "body": "* viśvasṛṣṭisthitidhvaṃseṣv aprakampasya yoginaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.32:13 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * uttīrṇadehaprāṇādipramātṛtvasya dhīmataḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.33:1 ||"
        },
        {
          "ref": null,
          "body": "* yato na tatsukhādyantas tata evaiṣa sādhakaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.33:11 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tābhyāṃ mukto viśeṣeṇa yogīndro yat tayor yataḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.34:1 ||"
        },
        {
          "ref": null,
          "body": "* tad evāha tuśabdoktam antaraṃ candraśekharaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.34:5 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * mohaḥ svākhyātir ajñānaṃ tena yaḥ pratisaṃhataḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.35:1 ||"
        },
        {
          "ref": null,
          "body": "* svātantryayogaḥ sahajaḥ prādurasti tadāsya tu ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.35:6 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * bhedasya dehaprāṇādimitāhaṃkṛtijanmanaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.36:1 ||"
        },
        {
          "ref": null,
          "body": "* na caitad apy asaṃbhāvyaṃ sraṣṭṛtvaṃ yogino yataḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.36:7 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * svataḥ svasmād anubhavāt svapnasaṃkalpanādiṣu ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.37:1 ||"
        },
        {
          "ref": null,
          "body": "* tirohitāyāḥ svātantryaśakter uttejanaṃ prati ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.37:8 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tripadaṃ jāgarāsvapnasauṣuptānām anukramāt ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.38:1 ||"
        },
        {
          "ref": null,
          "body": "* tripadādiprāṇanam ity etad uktam athāpi tu ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.38:15 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * anuprāṇanam ity etad ādadyād iti śiṣyate ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.39:1 ||"
        },
        {
          "ref": null,
          "body": "* apūrṇamanyatārūpād asyāṇavamalātmanaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.39:10 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tattvaiḥ śaktigaṇākrāntair dharaṇyantaiḥ kalādibhiḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.40:1 ||"
        },
        {
          "ref": null,
          "body": "* api tūktacarasvātmārāmataiveti kathyate ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.40:9 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tad ityuktacare dhāmni saṃvettṛtvasvarūpiṇi ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.41:1 ||"
        },
        {
          "ref": null,
          "body": "* ity āśaṅkyottaraṃ vakti bhagavān viśvadaiśikaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.41:9 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * tadety uktābhilāṣasya praśamāj jīvasaṃkṣaye ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.42:1 ||"
        },
        {
          "ref": null,
          "body": "* kasmād ity api śaṅkāyām uttaraṃ vakti śaṃkaraḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.42:9 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * prāṇe pariṇatā saṃvit prāg iti proktayā diśā ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.43:1 ||"
        },
        {
          "ref": null,
          "body": "* ity upāyopasaṃhāramukhenāha maheśvaraḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.43:20 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * netrādiromarandhrāntanāḍīnāṃ niviḍātmanām ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.44:1 ||"
        },
        {
          "ref": null,
          "body": "* upasaṃharati śrīmān uktaṃ prakaraṇaṃ śivaḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.44:17 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * punaś ca proktacaitanyasvarūponmīlanātmakam ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.45:1 ||"
        },
        {
          "ref": null,
          "body": "* anugṛhṇantu nāmaitat santaḥ saṃtoṣam āgatāḥ ||"
        },
        {
          "ref": null,
          "body": "SivSV_3.45:19 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        }
      ]
