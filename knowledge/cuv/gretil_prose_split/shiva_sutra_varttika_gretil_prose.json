          "ref": null,
          "body": "SivSV_1.14:5 ||"
        },
        {
          "ref": null,
          "body": "] ||"
        },
        {
          "ref": null,
          "body": "* [<śivasūtravārtika:> * vitarkaḥ proktasaṃdhānadhvastabandhasya yoginaḥ ||"
