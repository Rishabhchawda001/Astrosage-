[
  {
    "chunk_id": "e38febd04f95568dd0513460",
    "level": "verse",
    "scripture_id": "Brahmapurāṇa 1-246",
    "canonical_ref": "Brahmapurāṇa 1-246_ch0_aku?",
    "chapter": 0,
    "verse_range": "Brahmapurāṇa 1-246_ch0_aku?",
    "text": "oṃ viṣṇave namaḥ śiraḥ oṃ jvalanāya namaḥ śikhā | oṃ viṣṇave namaḥ kavacam oṃ viṣṇave namaḥ sphuraṇaṃ diśobandhāya | oṃ huṃphaḍastram oṃ śirasi śuklo vāsudeva iti | oṃ āṃ lalāṭe raktaḥ saṃkarṣaṇo garutmān vahnis teja āditya iti | oṃ āṃ grīvāyāṃ pītaḥ pradyumno vāyumegha iti | oṃ āṃ hṛdaye kṛṣṇo 'niruddhaḥ sarvaśaktisamanvita iti | evaṃ caturvyūham ātmānaṃ kṛtvā tataḥ karma samācaret ||",
    "entity_links": [],
    "relationship_links": [],
    "dialogue_links": [],
    "event_links": [],
    "concept_links": [],
