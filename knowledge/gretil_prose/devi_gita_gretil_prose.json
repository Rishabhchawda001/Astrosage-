      "akus": [
        {
          "ref": null,
          "body": "Devīgītā"
        },
        {
          "ref": null,
          "body": "atha prathamo 'dhyāyaḥ - saptamaḥ skandhaḥ atha ekatriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "janamejaya uvāca"
        },
        {
          "ref": null,
          "body": "vyāsa uvāca"
        },
        {
          "ref": null,
          "body": "devā ūcuḥ"
        },
        {
          "ref": null,
          "body": "śrīdevyuvāca"
        },
        {
          "ref": null,
          "body": "nirbhayā nirjarā rājannūcurduḥkhaṃ svakīyakam /"
        },
        {
          "ref": null,
          "body": "devā ūcuḥ"
        },
        {
          "ref": null,
          "body": "vyāsa uvāca"
        },
        {
          "ref": null,
          "body": "vyāsa uvāca"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ prathamo 'dhyāyaḥ - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāmekatriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "atha dvitīyo 'dhyāyaḥ - saptamaḥ skandhaḥ atha dvātriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "śrīdevyuvāca"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ dvitīyo 'dhyāyaḥ - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāṃ dvātriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "atha tṛtīyo 'dhyāyaḥ - saptamaḥ skandhaḥ atha trayastriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "devyuvāca"
        },
        {
          "ref": null,
          "body": "himālaya uvāca"
        },
        {
          "ref": null,
          "body": "vyāsa uvāca"
        },
        {
          "ref": null,
          "body": "bāṣpagadnadayā vācā stotuṃ samupacakrire /"
        },
        {
          "ref": null,
          "body": "devā ūcuḥ"
        },
        {
          "ref": null,
          "body": "vyāsa uvāca"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ tṛtīyo 'dhyāyaḥ - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāṃ trayastriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "atha caturtho 'dhyāyaḥ - saptamaḥ skandhaḥ atha catustriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "śrī devyuvāca"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ caturtho 'dhyāyaḥ - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāṃ catustriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "atha pañcamo 'dhyāyaḥ - saptamaḥ skandhaḥ atha pañcatriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "himālaya uvāca"
        },
        {
          "ref": null,
          "body": "śrīdevyuvāca"
        },
        {
          "ref": null,
          "body": "pradhānā merudaṇḍe 'tra candrasūryāgrarūpiṇī iḍā vāme sthitā nāḍī śubhrā tu candrarūpiṇī //"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ pañcamo 'dhyāyaḥ - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāṃ pañcatriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "atha ṣaṣṭho 'dhyāyaḥ - saptamaḥ skandhaḥ atha ṣaṭtriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "devyuvāca"
        },
        {
          "ref": null,
          "body": "lābdhā yena sa dhanyaḥ syāt kṛtakṛtyaśca bhūdhara"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ ṣaṣṭo 'dhyāyaḥ iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāṃ ṣaṭtriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "atha saptamo 'dhyāyaḥ - saptamaḥ skandhaḥ atha saptatriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "himālaya uvāca"
        },
        {
          "ref": null,
          "body": "devyuvāca"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ saptamo 'dhyāyaḥ - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāṃ saptatriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "aṣṭamo 'dhyāyaḥ saptamaḥ skandhaḥ athāṣṭatriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "himālaya uvāca"
        },
        {
          "ref": null,
          "body": "śrīdevyuvāca"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāmaṣṭamo 'dhyāya - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāmaṣṭatriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "navamo 'dhyāyaḥ saptamaḥ skandhaḥ athaikonacatvāriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "himālaya uvāca"
        },
        {
          "ref": null,
          "body": "śrīdevyuvāca"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ navamo 'dhyāyaḥ - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāmekonacatvāriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "daśamo 'dhyāyaḥ saptamaḥ skandhaḥ atha catvāriṃśo 'dhyāyaḥ"
        },
        {
          "ref": null,
          "body": "śrī devyuvāca"
        },
        {
          "ref": null,
          "body": "vyāsa uvāca"
        },
        {
          "ref": null,
          "body": "iti devīgītāyāṃ daśamo 'dhyāyaḥ devīgītā samāptā - iti śrīdevībhāgavate mahāpurāṇe saptamaskandhe devīgītāyāṃ catvāriṃśo 'dhyāyaḥ"
        }
      ]
