      "YVK": "YVK-CU-{kanda}.{prapathaka}.{anuvaka}.{verse}",
      "YVS": "YVS-CU-{adhyaya}.{verse}",
      "AV": "AV-CU-{kanda}.{sukta}.{verse}",
      "BG": "BG-CU-{adhyaya}.{verse}",
      "MBH": "MBH-CU-{parva}.{adhyaya}.{verse}",
      "RM": "RM-CU-{kanda}.{sarga}.{verse}",
      "HV": "HV-CU-{parva}.{adhyaya}.{verse}",
      "BHAG": "BHAG-CU-{skandha}.{adhyaya}.{verse}",
      "VISH": "VISH-CU-{amsha}.{adhyaya}.{verse}",
      "SHIV": "SHIV-CU-{samhita}.{adhyaya}.{verse}",
      "DEVI": "DEVI-CU-{skandha}.{adhyaya}.{verse}",
      "AGNI": "AGNI-CU-{adhyaya}.{verse}",
      "BRAH": "BRAH-CU-{adhyaya}.{verse}",
      "MATS": "MATS-CU-{adhyaya}.{verse}",
      "KURM": "KURM-CU-{adhyaya}.{verse}",
      "LING": "LING-CU-{adhyaya}.{verse}",
