      "BRAHMD": "BRAHMD-CU-{adhyaya}.{verse}",
      "KALI": "KALI-CU-{adhyaya}.{verse}",
      "GARUDA": "GARUDA-CU-{adhyaya}.{verse}",
      "ISHA": "ISHA-CU-{verse}",
      "KEN": "KEN-CU-{khanda}.{verse}",
      "KATH": "KATH-CU-{adhyaya}.{valli}.{verse}",
      "PRASHNA": "PRASHNA-CU-{prashna}.{verse}",
      "MUND": "MUND-CU-{mundaka}.{khanda}.{verse}",
      "MAND": "MAND-CU-{verse}",
