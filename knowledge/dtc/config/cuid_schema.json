      "BRIHAD": "BRIHAD-CU-{adhyaya}.{brahmana}.{verse}",
      "SHVET": "SHVET-CU-{adhyaya}.{verse}",
      "KAUS": "KAUS-CU-{adhyaya}.{verse}",
      "MAITR": "MAITR-CU-{prapathaka}.{verse}",
      "MAHAN": "MAHAN-CU-{anuvaka}.{verse}",
      "MANU": "MANU-CU-{adhyaya}.{verse}",
      "YAJNAV": "YAJNAV-CU-{adhyaya}.{verse}",
      "VISHNU_SM": "VISHNU_SM-CU-{adhyaya}.{verse}",
      "NARADA_SM": "NARADA_SM-CU-{adhyaya}.{verse}",
      "PARASHARA": "PARASHARA-CU-{adhyaya}.{verse}",
      "VYASA_SM": "VYASA_SM-CU-{adhyaya}.{verse}",
      "APASTAMBA_DS": "APASTAMBA_DS-CU-{prashna}.{adhyaya}.{verse}",
      "BAUDHAYANA_DS": "BAUDHAYANA_DS-CU-{prashna}.{adhyaya}.{verse}",
      "GAUTAMA_DS": "GAUTAMA_DS-CU-{adhyaya}.{verse}",
      "VEDANTA_SUTRA": "VEDANTA_SUTRA-CU-{adhyaya}.{pada}.{sutra}",
      "YOGA_SUTRA": "YOGA_SUTRA-CU-{pada}.{sutra}",
      "NYAYA_SUTRA": "NYAYA_SUTRA-CU-{adhyaya}.{sutra}",
      "VAISHESHIKA_SUTRA": "VAISHESHIKA_SUTRA-CU-{adhyaya}.{sutra}"
    },
    "permanent": true,
    "immutable": true,
    "namespace": "astrosage.dtc.cuid"
  },
  "structural_hierarchy": [
    "scripture",
    "book",
    "mandala",
    "skandha",
    "parva",
    "kanda",
    "adhyaya",
    "sarga",
    "prashna",
    "anuvaka",
    "brahmana",
    "khila",
    "sutra",
    "verse",
    "pada",
    "word",
    "akshara",
    "unicode_codepoint"
  ],
  "cuid_components": {
    "cuid": "string (primary key)",
    "scripture": "string (scripture_id)",
    "structural_position": "object with hierarchy levels",
    "canonical_text": "string (reconstructed reading)",
    "witness_families": "array of family_ids",
    "witness_families_independent": "array of independent family_ids",
    "witness_families_collated": "array of collated family_ids",
    "supporting_editions": "array of human-readable citations",
    "variant_readings": "array of variant objects",
    "variant_classification_policy": "string",
    "confidence": "object with independent_families_count and score",
    "evidence_chain": "array of evidence steps",
    "provenance": "object with repository, license, checksum",
    "falsification_status": "pending|survived|rejected"
  }
}
