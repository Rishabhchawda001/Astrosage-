{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Witness Record Schema",
  "type": "object",
  "required": ["witness_id", "canonical_name", "family_id", "editor", "publisher", "institution", "year", "language", "script", "encoding", "source_type", "critical_edition", "commentary", "recension", "shakha", "availability", "legal_status", "url", "checksum", "local_file", "acquisition_status", "authority_score", "reliability_score", "completeness_score", "digital_origin", "ocr_origin", "native_unicode", "tei_xml", "volume_count", "edition_family", "witness_family", "relationship_to_parent", "notes"],
  "properties": {
    "witness_id": {"type": "string", "pattern": "^[A-Z]{2,4}-W\\d{2,3}$"},
    "canonical_name": {"type": "string"},
    "alternative_names": {"type": "array", "items": {"type": "string"}},
    "iast_name": {"type": "string"},
    "devanagari_name": {"type": "string"},
    "family_id": {"type": "string", "pattern": "^F-[A-Z0-9-]+$"},
    "edition_id": {"type": "string"},
    "editor": {"type": "array", "items": {"type": "string"}},
    "publisher": {"type": "string"},
    "institution": {"type": "string"},
    "series": {"type": "string"},
    "repository": {"type": "string"},
    "year": {"type": ["integer", "null"]},
    "language": {"type": "string"},
    "script": {"type": "string"},
    "encoding": {"type": "string"},
    "source_type": {"type": "string", "enum": ["native_unicode", "ocr", "tei_xml", "pdf_scan", "manual_transcription", "derived_encoding"]},
    "critical_edition": {"type": "boolean"},
    "diplomatic_edition": {"type": "boolean"},
    "commentary": {"type": "string"},
    "padapatha": {"type": "boolean"},
    "samhitapatha": {"type": "boolean"},
    "khila": {"type": "boolean"},
    "recension": {"type": "string"},
    "shakha": {"type": "string"},
    "volume_count": {"type": "integer"},
    "availability": {"type": "string", "enum": ["open_access", "institutional", "public_domain", "copyrighted", "unknown"]},
    "legal_status": {"type": "string"},
    "url": {"type": "string"},
    "checksum": {"type": "string"},
    "local_file": {"type": "string"},
    "acquisition_status": {"type": "string", "enum": ["acquired", "discovered", "queued", "failed", "unavailable"]},
    "authority_score": {"type": "number", "minimum": 0, "maximum": 1},
    "reliability_score": {"type": "number", "minimum": 0, "maximum": 1},
    "completeness_score": {"type": "number", "minimum": 0, "maximum": 1},
    "digital_origin": {"type": "boolean"},
    "ocr_origin": {"type": "boolean"},
    "native_unicode": {"type": "boolean"},
    "tei_xml": {"type": "boolean"},
    "edition_family": {"type": "string"},
    "witness_family": {"type": "string"},
    "relationship_to_parent": {"type": "string", "enum": ["original", "digital_transcription", "ocr_derivative", "unicode_conversion", "reprint", "derived_edition", "re_encoding", "re_typesetting", "re_publication", "unknown"]},
    "notes": {"type": "string"}
  }
}
