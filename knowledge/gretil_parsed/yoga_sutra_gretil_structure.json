  "chapters": [
    {
      "chapter_num": 1,
      "verse_count": 195,
      "verse_groups": [
        {
          "lines": [
            "atha yogānuśāsanam || YS_1.1 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "yogaś cittavṛttinirodhaḥ || YS_1.2 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tadā draṣṭuḥ svarūpe 'vasthānam || YS_1.3 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vṛttisārūpyam itaratra || YS_1.4 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vṛttayaḥ pañcatayyaḥ kliṣṭākliṣṭāḥ || YS_1.5 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pramāṇaviparyayavikalpanidrāsmṛtayaḥ || YS_1.6 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pratyakṣānumānāgamāḥ pramāṇāni || YS_1.7 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "viparyayo mithyājñānam atadrūpapratiṣṭham || YS_1.8 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "śabdajñānānupātī vastuśūnyo vikalpaḥ || YS_1.9 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "abhāvapratyayālambanā vṛttir nidrā || YS_1.10 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "anubhūtaviṣayāsaṃpramoṣaḥ smṛtiḥ || YS_1.11 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "abhyāsavairāgyābhyāṃ tannirodhaḥ || YS_1.12 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tatra sthitau yatno 'bhyāsaḥ || YS_1.13 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sa tu dīrghakālanairantaryasatkārāsevito dṛḍhabhūmiḥ || YS_1.14 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "dṛṣṭānuśravikaviṣayavitṛṣṇasya vaśīkārasaṃjñā vairāgyam || YS_1.15 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tat paraṃ puruṣakhyāter guṇavaitṛṣṇyam || YS_1.16 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vitarkavicārānandāsmitārūpānugamāt saṃprajñātaḥ || YS_1.17 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "virāmapratyayābhyāsapūrvaḥ saṃskāraśeṣo 'nyaḥ || YS_1.18 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "bhavapratyayo videhaprakṛtilayānām || YS_1.19 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "śraddhāvīryasmṛtisamādhiprajñāpūrvaka itareṣām || YS_1.20 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tīvrasaṃvegānām āsannaḥ || YS_1.21 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "mṛdumadhyādhimātratvāt tato 'pi viśeṣaḥ || YS_1.22 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "īśvarapraṇidhānād vā || YS_1.23 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kleśakarmavipākāśayair aparāmṛṣṭaḥ puruṣaviśeṣa īśvaraḥ || YS_1.24 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tatra niratiśayaṃ sarvajñabījam || YS_1.25 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pūrveṣām api guruḥ kālenānavacchedāt || YS_1.26 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tasya vācakaḥ praṇavaḥ || YS_1.27 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tajjapas tadarthabhāvanam || YS_1.28 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tataḥ pratyakcetanādhigamo 'py antarāyābhāvaś ca || YS_1.29 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vyādhistyānasaṃśayapramādālasyāviratibhrāntidarśanālabdhabhūmikatvānavasthitatvāni cittavikṣepās te 'ntarāyāḥ || YS_1.30 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "duḥkhadaurmanasyāṅgamejayatvaśvāsapraśvāsā vikṣepasahabhuvaḥ || YS_1.31 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tatpratiṣedhārtham ekatattvābhyāsaḥ || YS_1.32 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "maitrīkaruṇāmuditopekṣāṇāṃ sukhaduḥkhapuṇyāpuṇyaviṣayāṇāṃ bhāvanātaś cittaprasādanam || YS_1.33 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pracchardanavidhāraṇābhyāṃ vā prāṇasya || YS_1.34 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "viṣayavatī vā pravṛttir utpannā manasaḥ sthitinibandhanī || YS_1.35 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "viśokā vā jyotiṣmatī || YS_1.36 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vītarāgaviṣayaṃ vā cittam || YS_1.37 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "svapnanidrājñānālambanaṃ vā || YS_1.38 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "yathābhimatadhyānād vā || YS_1.39 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "paramāṇuparamamahattvānto 'sya vaśīkāraḥ || YS_1.40 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kṣīṇavṛtter abhijātasyeva maṇer grahītṛgrahaṇagrāhyeṣu tatsthatadañjanatā samāpattiḥ || YS_1.41 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tatra śabdārthajñānavikalpaiḥ saṃkīrṇā savitarkā samāpattiḥ || YS_1.42 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "smṛtipariśuddhau svarūpaśūnyevārthamātranirbhāsā nirvitarkā || YS_1.43 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "etayaiva savicārā nirvicārā ca sūkṣmaviṣayā vyākhyātā || YS_1.44 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sūkṣmaviṣayatvaṃ cāliṅgaparyavasānam || YS_1.45 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tā eva sabījaḥ samādhiḥ || YS_1.46 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "nirvicāravaiśāradye 'dhyātmaprasādaḥ || YS_1.47 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "ṛtaṃbharā tatra prajñā || YS_1.48 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "śrutānumānaprajñābhyām anyaviṣayā viśeṣārthatvāt || YS_1.49 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tajjaḥ saṃskāro 'nyasaṃskārapratibandhī || YS_1.50 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tasyāpi nirodhe sarvanirodhān nirbījaḥ samādhiḥ || YS_1.51 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tapaḥsvādhyāyeśvarapraṇidhānāni kriyāyogaḥ || YS_2.1 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "samādhibhāvanārthaḥ kleśatanūkaraṇārthaś ca || YS_2.2 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "avidyāsmitārāgadveṣābhiniveśāḥ kleśāḥ || YS_2.3 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "avidyā kṣetram uttareṣāṃ prasuptatanuvicchinnodārāṇām || YS_2.4 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "anityāśuciduḥkhānātmasu nityaśucisukhātmakhyātir avidyā || YS_2.5 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "dṛgdarśanaśaktyor ekātmatevāsmitā || YS_2.6 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sukhānuśayī rāgaḥ || YS_2.7 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "duḥkhānuśayī dveṣaḥ || YS_2.8 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "svarasavāhī viduṣo 'pi tathā rūḍho 'bhiniveśaḥ || YS_2.9 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "te pratiprasavaheyāḥ sūkṣmāḥ || YS_2.10 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "dhyānaheyās tadvṛttayaḥ || YS_2.11 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kleśamūlaḥ karmāśayo dṛṣṭādṛṣṭajanmavedanīyaḥ || YS_2.12 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sati mūle tadvipāko jātyāyurbhogāḥ || YS_2.13 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "te hlādaparitāpaphalāḥ puṇyāpuṇyahetutvāt || YS_2.14 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pariṇāmatāpasaṃskāraduḥkhair guṇavṛttivirodhāc ca duḥkham eva sarvaṃ vivekinaḥ || YS_2.15 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "heyaṃ duḥkham anāgatam || YS_2.16 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "draṣṭṛdṛśyayoḥ saṃyogo heyahetuḥ || YS_2.17 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "prakāśakriyāsthitiśīlaṃ bhūtendriyātmakaṃ bhogāpavargārthaṃ dṛśyam || YS_2.18 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "viśeṣāviśeṣaliṅgamātrāliṅgāni guṇaparvāṇi || YS_2.19 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "draṣṭā dṛśimātraḥ śuddho 'pi pratyayānupaśyaḥ || YS_2.20 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tadartha eva dṛśyasyātmā || YS_2.21 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kṛtārthaṃ prati naṣṭam apy anaṣṭaṃ tadanyasādhāraṇatvāt || YS_2.22 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "svasvāmiśaktyoḥ svarūpopalabdhihetuḥ saṃyogaḥ || YS_2.23 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tasya hetur avidyā || YS_2.24 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tadabhāvāt saṃyogābhāvo hānaṃ taddṛśeḥ kaivalyam || YS_2.25 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vivekakhyātir aviplavā hānopāyaḥ || YS_2.26 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tasya saptadhā prāntabhūmiḥ prajñā || YS_2.27 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "yogāṅgānuṣṭhānād aśuddhikṣaye jñānadīptir ā vivekakhyāteḥ || YS_2.28 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "yamaniyamāsanaprāṇāyāmapratyāhāradhāraṇādhyānasamādhayo 'ṣṭāv aṅgāni || YS_2.29 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "ahiṃsāsatyāsteyabrahmacaryāparigrahā yamāḥ || YS_2.30 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "jātideśakālasamayānavacchinnāḥ sārvabhaumā mahāvratam || YS_2.31 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "śaucasaṃtoṣatapaḥsvādhyāyeśvarapraṇidhānāni niyamāḥ || YS_2.32 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vitarkabādhane pratipakṣabhāvanam || YS_2.33 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vitarkā hiṃsādayaḥ kṛtakāritānumoditā lobhakrodhamohapūrvakā mṛdumadhyādhimātrā duḥkhājñānānantaphalā iti pratipakṣabhāvanam || YS_2.34 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "ahiṃsāpratiṣṭhāyāṃ tatsaṃnidhau vairatyāgaḥ || YS_2.35 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "satyapratiṣṭhāyāṃ kriyāphalāśrayatvam || YS_2.36 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "asteyapratiṣṭhāyāṃ sarvaratnopasthānam || YS_2.37 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "brahmacaryapratiṣṭhāyāṃ vīryalābhaḥ || YS_2.38 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "aparigrahasthairye janmakathaṃtāsaṃbodhaḥ || YS_2.39 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "śaucāt svāṅgajugupsā parair asaṃsargaḥ || YS_2.40 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sattvaśuddhisaumanasyaikāgryendriyajayātmadarśanayogyatvāni ca || YS_2.41 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "saṃtoṣād anuttamaḥ sukhalābhaḥ || YS_2.42 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kāyendriyasiddhir aśuddhikṣayāt tapasaḥ || YS_2.43 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "svādhyāyād iṣṭadevatāsaṃprayogaḥ || YS_2.44 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "samādhisiddhir īśvarapraṇidhānāt || YS_2.45 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sthirasukham āsanam || YS_2.46 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "prayatnaśaithilyānantasamāpattibhyām || YS_2.47 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tato dvandvānabhighātaḥ || YS_2.48 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tasmin sati śvāsapraśvāsayor gativicchedaḥ prāṇāyāmaḥ || YS_2.49 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "bāhyābhyantarastambhavṛttir deśakālasaṃkhyābhiḥ paridṛṣṭo dīrghasūkṣmaḥ || YS_2.50 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "bāhyābhyantaraviṣayākṣepī caturthaḥ || YS_2.51 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tataḥ kṣīyate prakāśāvaraṇam || YS_2.52 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "dhāraṇāsu ca yogyatā manasaḥ || YS_2.53 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "svaviṣayāsaṃprayoge cittasvarūpānukāra ivendriyāṇāṃ pratyāhāraḥ || YS_2.54 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tataḥ paramā vaśyatendriyāṇām || YS_2.55 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "deśabandhaś cittasya dhāraṇā || YS_3.1 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tatra pratyayaikatānatā dhyānam || YS_3.2 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tad evārthamātranirbhāsaṃ svarūpaśūnyam iva samādhiḥ || YS_3.3 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "trayam ekatra saṃyamaḥ || YS_3.4 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tajjayāt prajñālokaḥ || YS_3.5 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tasya bhūmiṣu viniyogaḥ || YS_3.6 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "trayam antaraṅgaṃ pūrvebhyaḥ || YS_3.7 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tad api bahiraṅgaṃ nirbījasya || YS_3.8 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vyutthānanirodhasaṃskārayor abhibhavaprādurbhāvau nirodhakṣaṇacittānvayo nirodhapariṇāmaḥ || YS_3.9 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tasya praśāntavāhitā saṃskārāt || YS_3.10 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sarvārthataikāgratayoḥ kṣayodayau cittasya samādhipariṇāmaḥ || YS_3.11 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tataḥ punaḥ śāntoditau tulyapratyayau cittasyaikāgratāpariṇāmaḥ || YS_3.12 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "etena bhūtendriyeṣu dharmalakṣaṇāvasthāpariṇāmā vyākhyātāḥ || YS_3.13 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "śāntoditāvyapadeśyadharmānupātī dharmī || YS_3.14 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kramānyatvaṃ pariṇāmānyatve hetuḥ || YS_3.15 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pariṇāmatrayasaṃyamād atītānāgatajñānam || YS_3.16 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "śabdārthapratyayānām itaretarādhyāsāt saṃkaras tatpravibhāgasaṃyamāt sarvabhūtarutajñānam || YS_3.17 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "saṃskārasākṣātkaraṇāt pūrvajātijñānam || YS_3.18 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pratyayasya paracittajñānam || YS_3.19 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "na ca tat sālambanaṃ tasyāviṣayībhūtatvāt || YS_3.20 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kāyarūpasaṃyamāt tadgrāhyaśaktistambhe cakṣuḥprakāśāsaṃprayoge 'ntardhānam || YS_3.21 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sopakramaṃ nirupakramaṃ ca karma tatsaṃyamād aparāntajñānam ariṣṭebhyo vā || YS_3.22 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "maitryādiṣu balāni || YS_3.23 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "baleṣu hastibalādīni || YS_3.24 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pravṛttyālokanyāsāt sūkṣmavyavahitaviprakṛṣṭajñānam || YS_3.25 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "bhuvanajñānaṃ sūrye saṃyamāt || YS_3.26 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "candre tārāvyūhajñānam || YS_3.27 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "dhruve tadgatijñānam || YS_3.28 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "nābhicakre kāyavyūhajñānam || YS_3.29 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kaṇṭhakūpe kṣutpipāsānivṛttiḥ || YS_3.30 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kūrmanāḍyāṃ sthairyam || YS_3.31 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "mūrdhajyotiṣi siddhadarśanam || YS_3.32 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "prātibhād vā sarvam || YS_3.33 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "hṛdaye cittasaṃvit || YS_3.34 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sattvapuruṣayor atyantāsaṃkīrṇayoḥ pratyayāviśeṣo bhogaḥ parārthāt svārthasaṃyamāt puruṣajñānam || YS_3.35 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tataḥ prātibhaśrāvaṇavedanādarśāsvādavārtā jāyante || YS_3.36 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "te samādhāv upasargā vyutthāne siddhayaḥ || YS_3.37 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "bandhakāraṇaśaithilyāt pracārasaṃvedanāc ca cittasya paraśarīrāveśaḥ || YS_3.38 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "udānajayāj jalapaṅkakaṇṭakādiṣv asaṅga utkrāntiś ca || YS_3.39 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "samānajayāj jvalanam || YS_3.40 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "śrotrākāśayoḥ saṃbandhasaṃyamād divyaṃ śrotram || YS_3.41 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kāyākāśayoḥ saṃbandhasaṃyamāl laghutūlasamāpatteś cākāśagamanam || YS_3.42 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "bahir akalpitā vṛttir mahāvidehā tataḥ prakāśāvaraṇakṣayaḥ || YS_3.43 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sthūlasvarūpasūkṣmānvayārthavattvasaṃyamād bhūtajayaḥ || YS_3.44 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tato 'ṇimādiprādurbhāvaḥ kāyasaṃpat taddharmānabhighātaś ca || YS_3.45 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "rūpalāvaṇyabalavajrasaṃhananatvāni kāyasaṃpat || YS_3.46 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "grahaṇasvarūpāsmitānvayārthavattvasaṃyamād indriyajayaḥ || YS_3.47 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tato manojavitvaṃ vikaraṇabhāvaḥ pradhānajayaś ca || YS_3.48 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sattvapuruṣānyatākhyātimātrasya sarvabhāvādhiṣṭhātṛtvaṃ sarvajñātṛtvaṃ ca || YS_3.49 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tadvairāgyād api doṣabījakṣaye kaivalyam || YS_3.50 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sthānyupanimantraṇe saṅgasmayākaraṇaṃ punar aniṣṭaprasaṅgāt || YS_3.51 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kṣaṇatatkramayoḥ saṃyamād vivekajaṃ jñānam || YS_3.52 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "jātilakṣaṇadeśair anyatānavacchedāt tulyayos tataḥ pratipattiḥ || YS_3.53 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tārakaṃ sarvaviṣayaṃ sarvathāviṣayam akramaṃ ceti vivekajaṃ jñānam || YS_3.54 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sattvapuruṣayoḥ śuddhisāmye kaivalyam iti || YS_3.55 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "janmauṣadhimantratapaḥsamādhijāḥ siddhayaḥ || YS_4.1 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "jātyantarapariṇāmaḥ prakṛtyāpūrāt || YS_4.2 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "nimittam aprayojakaṃ prakṛtīnāṃ varaṇabhedas tu tataḥ kṣetrikavat || YS_4.3 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "nirmāṇacittāny asmitāmātrāt || YS_4.4 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pravṛttibhede prayojakaṃ cittam ekam anekeṣām || YS_4.5 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tatra dhyānajam anāśayam || YS_4.6 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "karmāśuklākṛṣṇaṃ yoginas trividham itareṣām || YS_4.7 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tatas tadvipākānuguṇānām evābhivyaktir vāsanānām || YS_4.8 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "jātideśakālavyavahitānām apy ānantaryaṃ smṛtisaṃskārayor ekarūpatvāt || YS_4.9 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tāsām anāditvaṃ cāśiṣo nityatvāt || YS_4.10 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "hetuphalāśrayālambanaiḥ saṃgṛhītatvād eṣām abhāve tadabhāvaḥ || YS_4.11 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "atītānāgataṃ svarūpato 'sty adhvabhedād dharmāṇām || YS_4.12 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "te vyaktasūkṣmā guṇātmānaḥ || YS_4.13 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "pariṇāmaikatvād vastutattvam || YS_4.14 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "vastusāmye cittabhedāt tayor vibhaktaḥ panthāḥ || YS_4.15 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "na caikacittatantraṃ vastu tadapramāṇakaṃ tadā kiṃ syāt || YS_4.16 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "taduparāgāpekṣitvāc cittasya vastu jñātājñātam || YS_4.17 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "sadā jñātāś cittavṛttayas tatprabhoḥ puruṣasyāpariṇāmitvāt || YS_4.18 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "na tat svābhāsaṃ dṛśyatvāt || YS_4.19 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "ekasamaye cobhayānavadhāraṇam || YS_4.20 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "cittāntaradṛśye buddhibuddher atiprasaṅgaḥ smṛtisaṃkaraś ca || YS_4.21 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "citer apratisaṃkramāyās tadākārāpattau svabuddhisaṃvedanam || YS_4.22 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "draṣṭṛdṛśyoparaktaṃ cittaṃ sarvārtham || YS_4.23 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tad asaṃkhyeyavāsanābhiś citram api parārthaṃ saṃhatyakāritvāt || YS_4.24 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "viśeṣadarśina ātmabhāvabhāvanānivṛttiḥ || YS_4.25 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tadā vivekanimnaṃ kaivalyaprāgbhāraṃ cittam || YS_4.26 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tacchidreṣu pratyayāntarāṇi saṃskārebhyaḥ || YS_4.27 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "hānam eṣāṃ kleśavad uktam || YS_4.28 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "prasaṃkhyāne 'py akusīdasya sarvathā vivekakhyāter dharmameghaḥ samādhiḥ || YS_4.29 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tataḥ kleśakarmanivṛttiḥ || YS_4.30 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tadā sarvāvaraṇamalāpetasya jñānasyānantyāj jñeyam alpam || YS_4.31 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "tataḥ kṛtārthānāṃ pariṇāmakramasamāptir guṇānām || YS_4.32 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "kṣaṇapratiyogī pariṇāmāparāntanirgrāhyaḥ kramaḥ || YS_4.33 ||"
          ],
          "line_count": 1
        },
        {
          "lines": [
            "puruṣārthaśūnyānāṃ guṇānāṃ pratiprasavaḥ kaivalyaṃ svarūpapratiṣṭhā vā citiśaktir iti || YS_4.34 ||"
          ],
          "line_count": 1
        }
      ]
    }
  ]
}