{
  "file": "sa_brahmagupta-brAhmasphuTasiddhAnta.xml",
  "xml_id": "sa_brahmagupta-brAhmasphuTasiddhAnta",
  "title": "Brāhmasphuṭasiddhānta",
  "total_chapters": 1,
  "total_verses": 214,
  "chapters": [
    {
      "chapter_num": 1,
      "verse_count": 214,
      "verse_groups": [
        {
          "lines": [
            "parikarma-%viṃśatim yas saṅkalita-ādyām pṛthak vijānāti/",
            "%aṣṭau ca vyavahārān chāyā-antān bhavati gaṇakas sas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "viparīta-cheda-guṇās rāśyos cheda-aṃśakās sama-chedās/",
            "saṅkalite aṃśās yojyās vyavakalite aṃśa-antaram kāryam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "rūpāṇi cheda-guṇāni aṃśa-yutāni %dvayos bahūnām vā/",
            "pratyutpannas bhavati cheda-vadhena uddhṛtas aṃśa-vadhas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "parivartya bhāga-hāra-cheda-aṃśau cheda-saṃguṇa-chedas/",
            "aṃśas aṃśa-guṇas bhājyasya bhāga-hāras savarṇitayos//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "saṃvarṇita--aṃśa-vargas cheda-kṛti-vibhājitas bhavati vargas/",
            "saṃvarṇita-aṃśa-mūlam cheda-padena uddhṛtam mūlam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "sthāpyas antya-ghanas antya-kṛtis %tri-guṇa-uttara-saṅguṇā ca tad-%prathamāt/",
            "uttara-kṛtis antya-guṇā %tri-guṇā ca uttara-ghanas ca ghanas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "chedas ghanāt %dvitīyāt ghana-mūla-kṛtis %tri-saṅguṇā āpta-kṛtis/",
            "śodhyā %tri-pūrva-guṇitā %prathamāt ghanatas ghanas mūlam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "sadṛśa-cheda-aṃśa-yutis cheda-vibhaktā phalam %prathama-jātau/",
            "aṃśais aṃśās guṇitās chedais chedās %dvitīyāyām//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "ūrdhva-aṃśās cheda-guṇās %tṛtīya-jātau %dvayos %prathama-parayos/",
            "chedais chedās guṇitās sva-aṃśa-yuta-ūnais upari-ga-aṃśās//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "trairāśike pramāṇam phalam iccā ādi-antayos sadṛśa-rāśī/",
            "icchā phalena guṇitā pramāṇa-bhaktā phalam bhavati//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "vyasta-trairāśika-phalam icchā-bhaktas pramāṇa-phala-ghātas/",
            "trairāśika-ādiṣu phalam viṣameṣu %ekādaśa-anteṣu//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "phala-saṅkramaṇam ubhaya-tas bahu-rāśi-vadhas alpa-vadha-hṛtas jñeyam/",
            "sakaleṣu evam bhinneṣu ubhaya-tas cheda-saṅkramaṇam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "prāk mūlya-vyatyāsas bhāṇḍapratibhāṇḍake anyat ukta-samam/",
            "parikarmāṇi %aṣṭānām vyavahārāṇām abhihitāni//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "kāla-guṇitam pramāṇam phala-bhaktam vi-%eka-guṇa-hatam kālas/",
            "sva-phala-yuta-#rūpa-bhaktam mūla-phala-aikyam bhavati mūlam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "kāla-pramāṇa-ghātas para-kāla-hṛtas dvidhā ādya-miśra-vadhāt/",
            "anya-%ardha-kṛti-yutāt padam anya-%ardha-ūnam pramāṇa-phalam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "prakṣepa-yoga-hṛtayā labdhyā prakṣepakās guṇās lābhās/",
            "ūna-adhika-uttarās tad-yuta-ūnayā sva-phalam ūna-yutam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "padam %eka-hīnam uttara-guṇitam saṃyuktam ādinā antya-dhanam/",
            "ādi-yuta-antya-dhana-%ardham madhya-dhanam pada-guṇam gaṇitam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "uttara-hīna-%dvi-guṇa-ādi-śeṣa-vargam dhana-uttara-%aṣṭa-vadhe/",
            "prakṣipya padam śeṣa-ūnam %dvi-guṇa-uttara-hṛtam gacchas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "%eka-uttaram %eka-ādyam yadi iṣṭa-gacchasya bhavati saṅkalitam/",
            "tat %dvi-yuta-gaccha-guṇitam %tri-hṛtam saṅkalita-saṅkalitam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "%dvi-guṇa-pada-sa-%eka-guṇitam tat %tri-hṛtam bhavati varga-saṅkalitam/",
            "ghana-saṅkalitam tad-kṛtis eṣām sama-golakais citayas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "sthūla-phalam %tri-%catur-bhuja-bāhu-pratibāhu-yoga-#dala-ghātas/",
            "bhuja-yoga-%ardha-%catuṣṭaya-bhuja-ūna-ghātāt padam sūkṣmam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "bhuja-kṛti-antara-bhū-hṛta-hīna-yutā bhūs %dvi-bhājitā āvādhe/",
            "sva-āvādhā-varga-ūnāt bhuja-vargāt mūlam avalambas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "aviṣama-%catur-asra-bhuja--pratibhuja-vadhayos yutes padam karṇas/",
            "karṇa-kṛtis bhū-mukha-yuti-#dala-varga-ūnā padam lambas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "karṇa-kṛtes koṭi-kṛtim viśodhya mūlam bhujas bhujasya kṛtim/",
            "prohya padam koṭis koṭi-bāhu-kṛti-yuti-padam karṇas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "karṇa-yutau ūrdhva-adhara-khaṇḍe karṇa-avalamba-yoge vā/",
            "sva-āvādhe sva-yuti-hṛte dvidhā pṛthak karṇa-lamba-guṇe//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "aviṣama-pārśva-bhuja-guṇas karṇas %dvi-guṇa-avalambaka-vibhaktas/",
            "hṛdayam viṣamasya bhuja-pratibhuja-kṛti-yoga-mūla-%ardham//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "%tri-bhujasya vadhas bhujayos %dvi-guṇita-lamba-uddhṛtas hṛdaya-rajjus/",
            "sā %dvi-guṇā %tri-%catur-bhuja-koṇa-spṛk vṛtta-viṣkambhas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "karṇa-āśrita-bhuja-ghāta-aikyam ubhayathā anyonya-bhājitam guṇayet/",
            "yogena bhuja-pratibhuja-vadhayos karṇau pade viṣame//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "viṣama-%catur-asra-madhye viṣama-%tri-bhuja-%dvayam prakalpya pṛthak/",
            "karṇa-%dvayena pūrva-vat āvādhe lambakau ca pṛthak//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "viṣama-bhuja-antar-%tri-bhuje prakalpya karṇau bhujau tad-āvādhe/",
            "pṛthak ūrdhva-adhara-khaṇḍe karṇa-yutau karṇayos adhare//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "%tri-bhje bhujau tu bhūmis tad-lambas lambaka-adharam khaṇḍam/",
            "ūrdhvam avalamba-khaṇḍam lambaka-yoga-%ardham adhara-ūnam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "karṇa-avalambaka-yutau khaṇḍe karṇa-avalambakayos adhare/",
            "anupātena tad-ūne ūrdhve sūcyām sa-pāṭāyām//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "kṛti-yutis asadṛśa-rāśyos bāhus ghātas %dvi-saṅguṇas lambas/",
            "kṛti-antaram asadṛśayos %dvi-guṇam %dvi-sama-%tri-bhuja-bhūmis//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "iṣṭa-%dvayena bhaktas dvidhā iṣṭa-vargas phala-iṣṭa-yoga-%ardhe/",
            "viṣama-%tri-bhujasya bhujau iṣṭa-ūna-phala-%ardha-yogas bhūs//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "iṣṭasya bhujasya kṛtis bhaktā ūnā iṣṭena tad-#dalam koṭis/",
            "āyata-%catur-asrasya kṣetrasya iṣṭa-adhikā karṇas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "āyata-karṇas bāhū bhuja-kṛtis iṣṭena bhājitā iṣṭa-ūnā/",
            "%dvi-hṛtā koṭi-adhikā bhūs mukham ūnā %dvi-sama-%catur-asre//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "karṇa-kṛtis %tri-sama-hbujās %trayas %caturthas viśodhya koṭi-kṛtim/",
            "bāhu-kṛtes %tri-guṇāyās yadi adhikas bhūs mukham hīnas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "jātya-%dvaya-koṭi-bhujās para-karṇa-guṇās bhujās %catur-viṣame/",
            "adhikas bhūs mukha-hīnas bāhu-%dvitayam bhujau anyau//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "iṣṭa-guṇa-kāra-guṇitas giri-ucchrāyas pura-antaram anaṣṭam/",
            "%dvi-yuta-guṇa-kāra-bhājitam utpātas anyasya sama-gatyos//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "vyāsa-vyāsa-%ardha-kṛtī paridhi-phale vyāvahārike %tri-guṇe/",
            "tad-vargābhyām %daśabhis saṅguṇitābhyām pade sūkṣme//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "vṛtte śara-ūna-guṇitāt vyāsāt %catur-āhatāt padam jīvā/",
            "jyā-vargas %catur-āhata-śara-bhaktas śara-yutas vyāsas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "jyā-vyāsa-kṛti-viśeṣāt mūla-vyāsa-antara-%ardham iṣus alpas/",
            "vyāsau grāsa-ūna-guṇau grāsa-ūna-aikya-uddhṛtau bāṇau//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "iṣṭa-śara-%dvaya-bhakte jyā-%ardha-kṛtī śara-yute phale vyāsau/",
            "śarayos phalayos aikyam grāsas grāsa-ūnam aikyam tat//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "kṣetra-phalam vedha-guṇam sama-khāta-phalam hṛtam %tribhis sūcyās/",
            "mukha-tala-tulya-bhuja-aikyāni %eka-agra-hṛtāni sama-rajjus//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "mukha-tala-yuti-#dala-gaṇitam vedha-guṇam vyāvahārikam gaṇitam/",
            "mukha-tala-gaṇita-aikya-%ardham vedha-guṇam syāt gaṇitam autram//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "autra-gaṇitāt viśodhya vyavahāra-phalam bhajet %tribhis śeṣam/",
            "labdham vyavahāra-phale prakṣipya bhavati phalam sūkṣmam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "ākṛti-phalam auccya-āhatam agra-tala-aikya-%ardham auccya-dairghya-guṇam/",
            "ghana-gaṇitam iṣṭakā-ghana-phalena hṛtam iṣṭakā-gaṇitam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "vistāra-āyāma-aṅgula-ghātas mārga-āhatas %dvi-#veda-hṛtas/",
            "kiṣku-aṅgulāni labdham tat %ṣaṇṇavatis bhavati karma//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "śākā-ādiṣu śālmalyām %śata-%dvayam bījake %śatam %viṃśam/",
            "śāla-sarala-ādiṣu %śatam atha avi-dāruṣu %catuḥṣaṣṭis/"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "%navamas śūkiṣu %daśamas sthūleṣu %ekādaśas bhavati aṇuṣu/",
            "paridhes vedhas paridhes %ṣaṣ-aṃśa-varga-āhatas gaṇitam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "%dvi-%catur-sa-%tri-aṃśa-guṇas bhitti-antar-vāhya-koṇa-gas paridhis/",
            "prāk-vat kṛtvā gaṇitam tad-gaṇitam sva-guṇa-kāra-hṛtam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "chāyā-nara-sa-%eka-hṛtam dyu-#dalam prāk-aparayos dyu-gata-śeṣam/",
            "dina-gata-śeṣa-aṃśa-hṛtam dyu-#dalam chāyā-nara-vi-%ekam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "dīpa-tala-śaṅku-talayos antaram iṣṭa-pramāṇa-śaṅku-guṇam/",
            "dīpa-śikha-auccyāt śaṅkum viśodhya śeṣa-uddhṛtam chāyā//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "chāyā-agra-antara-guṇitā chāyā chāyā-antareṇa bhaktā bhūs/",
            "bhūs śaṅku-guṇā chāyā-vibhājitā dīpa-śikhayā auccyam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "guṇa-kāra-khaṇḍa-tulyas guṇyas go-mūtrikā-kṛtas guṇitas/",
            "sahitas pratyutpannas guṇa-kāraka-bheda-tulyas vā//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "guṇyas rāśis guṇa-kāra-rāśinā iṣṭa-adhika-ūnakena guṇas/",
            "guṇya-iṣṭa-vadha-ūna-yutas guṇake abhyadhika-ūnake kāryas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "chedena iṣṭa-yuta-ūnena āptam bhājyāt anaṣṭam iṣṭa-guṇam/",
            "prakṛti-stha-cheda-hṛtam labdhyā yuta-hīnakam anaṣṭam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "guṇyas cheda-phala-vadhas guṇaka-hṛtas guṇya-bhājitas guṇakas/",
            "cheda-uddhṛtas phalam guṇya-guṇa-vadhas phala-hṛtas chedas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "guṇya-guṇa-kārayos cheda-labdhayos yadi %dvayos %dvayos nāśas/",
            "teṣām dṛśyau vyastau kṛtvā tad-sthānayos ca iṣṭau//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "guṇyam guṇa-kāram vā guṇayet chedena bhāga-hārasya/",
            "guṇya-guṇa-kāra-rāśyos cheda-guṇas bhāga-hāras ca//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "acchedasya chedam #rūpam kṛtvā anyat ukta-vat sarvam/",
            "apavartyau cheda-guṇau tulyena iṣṭena guṇyau vā//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "sva-vikala-%ṣaṣṭi-aṃśa-guṇas sakalas %triṃśa-uddhṛtas vikala-vargas/",
            "prakṣepyas sakala-kṛtau varga-ghanau %dvi-%tri-tulya-vadhau//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "rāśes ūnam %dvi-guṇam bahutara-guṇam ūna-kṛti-yutam vargas/",
            "rāśes iṣṭa-yuta-ūnāt vadhas kṛtis vā iṣṭa-kṛti-yuktas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "iṣṭa-alpa-rāśi-vargau yukta-ūnau itara-vikala-vargābhyām/",
            "%dvi-guṇa-itara-rāśibhyām bhaktau tena adhika-ūnābhyām//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "sthāna-antareṣu labdham yena samam phala-yuta-ūnaka-chedas/",
            "dalitas kṛti-yoga-antara-padam itaras vā phala-yuta-ūnas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "dik-mātram etat anyat jyā-utpattau kuṭṭake ca kathayiṣye/",
            "saṅkalita-ādiṣu āryās %ṣaṭṣaṣṭis %dvādaśas adhyāyas//",
            "iti śrī-brāhma-sphuṭa-siddhānte %dvādaśas adhyāyas//12//"
          ],
          "line_count": 3
        },
        {
          "lines": [
            "prāyeṇa yatas praśnās kuṭṭākārāt ṛte na śakyante/",
            "jñātum vakṣyāmi tatas kuṭṭākāram saha praśnais//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "kuṭṭaka-#kha-ṛṇa-dhana-avyakta-madhya-haraṇa-%eka-varṇa-bhāvitakais/",
            "ācāryas tantra-vidām jñātais varga-prakṛtyā ca//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "adhika-agra-bhāga-hārāt ūna-agra-cheda-bhājitāt śeṣam/",
            "yat tat paraspara-hṛtam labdham adhas adhas pṛthak sthāpyam//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "śeṣam tathā iṣṭa-guṇitam yathā agrayos antareṇa saṃyuktam/",
            "śudhyati guṇakas sthāpyas labdham ca antyāt upāntya-guṇas//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "sva-ūrdhvas antya-yutas agra-antas hīna-agra-cheda-bhājitas śeṣam/",
            "adhika-agra-cheda-hatam adhika-agra-yutam bhavati agram//"
          ],
          "line_count": 2
        },
        {
          "lines": [
            "cheda-vadhasya %dvi-yugam cheda-vadhas yuga-gatam %dvayos agram/",
            "kuṭṭākāreṇa evam %tri-ādi-graha-yuga-gata-ānayanam//"
          ],
          "line_count": 2
        },
