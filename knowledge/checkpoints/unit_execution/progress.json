    "\u0cad\u0cc0\u0cb7\u0ccd\u0cae \u0caa\u0cbf\u0ca4\u0cbe\u0cae\u0cb9\u0cb0 \u0c95\u0ca5\u0cc6_",
    "\u0cae\u0cb9\u0cbe\u0cad\u0cbe\u0cb0\u0ca4\u0ca6 \u0c86\u0ca6\u0cb0\u0ccd\u0cb6_",
    "\u0cb5\u0cbe\u0cb8\u0ccd\u0ca4\u0cb5\u0cbf\u0c95 \u0cb8\u0cc1\u0c96 \u0c86\u0ca8\u0c82\u0ca6_",
    "\u0cb5\u0cbf\u0cb7\u0ccd\u0ca3\u0cc1 \u0cb8\u0cb9\u0cb8\u0ccd\u0cb0 \u0ca8\u0cbe\u0cae_",
    "\u0cb6\u0cbf\u0c95\u0ccd\u0cb7\u0caa\u0ccd\u0cb0\u0ca6_",
    "\u0cb8\u0c82\u0caa\u0cc2\u0cb0\u0ccd\u0ca3 \u0c8b\u0c97\u0ccd\u0cb5\u0cc7\u0ca6 \u0c95\u0ca8\u0ccd\u0ca8\u0ca1 ",
    "\u0cb8\u0cae\u0caf\u0ca6 \u0cb8\u0ca6\u0cc1\u0caa\u0caf\u0ccb\u0c97 \u0cb9\u0cc7\u0c97\u0cc6_"
  ]
}